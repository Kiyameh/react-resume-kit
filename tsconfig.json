{
  "compilerOptions": {
    "declaration": true,
    "outDir": "dist",
    "declarationDir": "dist/types",
    "target": "es5",
    "module": "esnext",
    "jsx": "react",
    "sourceMap": true,
    "strict": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "node"
  },
  "include": ["src/**/*", "package/**/*"],
  "exclude": ["node_modules", "dist", "demo", "src/data"]
}
